# Conman Server Configuration
# Edit this file and restart: systemctl restart conman-server

PORT=5173
DATABASE_DRIVER=sqlite
DATABASE_URL=/var/lib/conman/app.db
# DATABASE_DRIVER=postgres
# DATABASE_DSN=host=localhost port=5432 user=conman password=conman dbname=conman sslmode=disable

SECRET_KEY=change-me-in-production
MASTER_API_KEY=change-me-in-production
AGENT_TOKEN=change-me-in-production

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin

STATIC_DIR=/usr/share/conman/static
DOCKER_HOST=unix:///var/run/docker.sock
CORS_ORIGINS=http://localhost:5173

# Licensing (leave empty for Community/Free tier)
LICENSE_KEY=
KEYGEN_ACCOUNT_ID=
KEYGEN_PRODUCT_ID=
