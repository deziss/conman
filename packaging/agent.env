# Conman Agent Configuration
# Edit this file and restart: systemctl restart conman-agent

# AGENT_NAME defaults to hostname if not set
# AGENT_NAME=my-host

CONMAN_SERVER_URL=http://localhost:5173
CONMAN_SERVER_TOKEN=change-me-in-production

# Runtime auto-detection (auto | docker | podman | containerd)
RUNTIME_TYPE=auto
# RUNTIME_SOCKET_PATH=/var/run/docker.sock
# CONTAINERD_NAMESPACE=default

AGENT_MODE=hybrid
COLLECT_INTERVAL=10s
SCRAPE_PORT=5073
SCRAPE_ENABLED=true
