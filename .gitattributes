# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Documents
*.md text diff=markdown
*.txt text
*.pdf binary

# Scripts
*.sh text eol=lf
*.bash text eol=lf
*.py text diff=python
*.js text
*.ts text

# Graphics
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.svg text

# Archives
*.7z binary
*.gz binary
*.tar binary
*.tgz binary
*.zip binary

# Fonts
*.ttf binary
*.eot binary
*.otf binary
*.woff binary
*.woff2 binary